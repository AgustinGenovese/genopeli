{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/main.ts",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      "src": "/search(.*)",
      "dest": "backend/src/main.ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "backend/src/main.ts"
    },
    {
      "src": "/(assets|.*\\.js|.*\\.css|.*\\.png|.*\\.jpg|.*\\.svg|.*\\.ico)",
      "dest": "frontend/dist/frontend/browser/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/dist/frontend/browser/index.html"
    }
  ]
}
